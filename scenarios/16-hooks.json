        { "label": "다른 Hook 예시 보여줘", "correct": false, "hint": "직접 실용적인 Hook을 추가해봐요!" }
      ]
    },
    {
      "type": "output",
      "lines": [
        { "text": "Notification Hook을 추가합니다.", "delay": 400 },
        { "text": "", "delay": 200 },
        { "text": "Edit .claude/settings.json", "style": "dim", "delay": 500 },
        { "text": "", "delay": 200 },
        { "text": "추가된 Hook:", "style": "success", "delay": 300 },
        { "text": "  이벤트: Notification", "delay": 300 },
