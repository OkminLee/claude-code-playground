    {
      "type": "prompt",
      "cwd": "~/my-app",
      "choices": [
        { "label": "/cost", "correct": true },
        { "label": "비용 얼마야?", "correct": false, "hint": "비용 확인은 /cost 커맨드로 할 수 있어요." }
      ]
    },
    {
      "type": "output",
      "lines": [
        { "text": "현재 세션 비용:", "style": "info", "delay": 300 },
        { "text": "", "delay": 200 },
        { "text": "  입력 토큰:   12,847  ($0.038)", "delay": 300 },
        { "text": "  출력 토큰:    3,241  ($0.049)", "delay": 300 },
        { "text": "  캐시 읽기:   45,000  ($0.005)", "style": "dim", "delay": 300 },
        { "text": "", "delay": 200 },
        { "text": "  총 비용: $0.092", "style": "success", "delay": 400 }
