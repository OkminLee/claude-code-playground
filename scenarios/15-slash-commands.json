    },
    {
      "type": "prompt",
      "cwd": "~/my-app",
      "choices": [
        { "label": "/review", "correct": true },
        { "label": "코드 리뷰해줘", "correct": false, "hint": "/review 커맨드를 사용하면 구조화된 코드 리뷰를 받을 수 있어요." }
      ]
    },
    {
      "type": "output",
